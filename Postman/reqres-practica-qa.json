					"name": "Listar Usuarios Página 1",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code es 200\", function(){\r",
									"    pm.response.to.have.status(200);\r",
									"    });\r",
									"pm.test(\"Response tiene datos de usuarios\", function(){\r",
									"    var json = pm.response.json();\r",
									"    pm.expect(json.data).to.be.an(\"array\");\r",
									"    });\r",
									"pm.test(\"La página actual es 1\", function(){\r",
									"    var json = pm.response.json();\r",
									"    pm.expect(json.page).to.eql(1);\r",
									"    });\r",
									"pm.test(\"Tiempo de respuesta menor a 20ms\", function(){\r",
									"    pm.expect(pm.response.responseTime).to.be.below(20);\r",
									"    });"
								],
								"type": "text/javascript"
							}
						}
					],
